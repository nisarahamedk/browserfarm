{
  "name": "browserfarm",
  "version": "0.1.0",
  "description": "Lightweight local browser session manager for agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "smoke:container": "docker run --rm -e BROWSERFARM_URL -e BROWSERFARM_AUTH_TOKEN -v \"$PWD\":/work -w /work node:22-alpine node scripts/smoke-container.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "hono": "^4.12.11",
    "nanoid": "^5.1.6",
    "ws": "^8.20.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.15.1"
}
